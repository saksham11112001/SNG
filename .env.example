# .env.example
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Cookie domain ─────────────────────────────────────────────
# LOCAL DEV:   localhost
# PRODUCTION:  .sngadvisors.com   (leading dot = all subdomains)
NEXT_PUBLIC_COOKIE_DOMAIN=localhost

# ── Product URLs ──────────────────────────────────────────────
# LOCAL DEV:   http://localhost:3001 and http://localhost:3002
# PRODUCTION:  https://tasks.sngadvisors.com and https://fms.sngadvisors.com
NEXT_PUBLIC_PLANORA_URL=http://localhost:3001
NEXT_PUBLIC_FLOWOS_URL=http://localhost:3002

# ── Site URL ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
